# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/autofill_db

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=AutoFill AI System

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:8000"]

# AI Configuration
TOP_SUGGESTIONS_COUNT=3
HISTORY_LOOKBACK_DAYS=30
MIN_HISTORY_ENTRIES=5

# AI Composer Configuration
# AI_PROVIDER có thể là: "openai", "gemini" hoặc "openrouter"
AI_PROVIDER=openrouter
# AI_PROFILE điều khiển thứ tự ưu tiên provider: auto | openrouter | openai | gemini
# - auto: ưu tiên openrouter (model free) rồi fallback sang openai nếu có key
AI_PROFILE=auto
AI_FAILOVER_ENABLED=true
# Với openai/gemini: dùng AI_API_KEY
AI_API_KEY=
# Model cho OpenAI provider
AI_MODEL=gpt-4o-mini

# OpenAI (khuyến nghị dùng riêng key thay vì dùng chung AI_API_KEY)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4o,gpt-3.5-turbo

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Danh sách model thử lần lượt khi model chính lỗi (phân tách bởi dấu phẩy)
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemma-4-31b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,minimax/minimax-m2.5:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-20b:free
OPENROUTER_AUTO_FAILOVER=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AutoFill AI System

COMPOSER_MAX_SUGGESTIONS=3
COMPOSER_SUGGESTION_LENGTH=10

# App URL (used for building email verification links)
APP_BASE_URL=http://localhost:8000

# RAG / semantic memory
RAG_ENABLED=true
RAG_EMBEDDING_MODEL=text-embedding-3-small
# Requires OPENAI_API_KEY (recommended) or AI_PROVIDER=openai with AI_API_KEY
RAG_SEMANTIC_TOP_K=5
RAG_MAX_CHUNKS_SCAN=2000
RAG_CHUNK_CHAR_LIMIT=480
RAG_CHUNK_OVERLAP=64
RAG_EMBED_BATCH_SIZE=64

# SMTP email configuration (required for production signup verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AutoFill AI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_VERIFICATION_TTL_HOURS=24

# Google OAuth (login with Google for users whose email already exists in system)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_OAUTH_STATE_TTL_SECONDS=600

# Payment gateway configuration
# PAYMENT_GATEWAY: vnpay | sepay
PAYMENT_GATEWAY=vnpay

# VNPay (sandbox/default)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# URL public để VNPay redirect người dùng sau thanh toán
VNPAY_RETURN_URL=http://localhost:8000/api/payments/vnpay/return
# Tùy chọn: ép cổng ngân hàng (ví dụ NCB, VCB,...)
VNPAY_BANK_CODE=
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other

# SePay (fallback nếu cần)
SEPAY_API_KEY=
SEPAY_CREATE_ORDER_URL=
SEPAY_ORDER_STATUS_URL=
SEPAY_WEBHOOK_URL=
SEPAY_WEBHOOK_SECRET=
